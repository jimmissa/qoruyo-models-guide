.DS_Store
.venv/
__pycache__/
*.pyc

# Model binaries remain on Zenodo and are not committed here.
*.mlmodel
models/

# User inputs and generated OCR outputs.
images/
input/
output/
*.txt
!README.md
!NOTICE.md
!docs/*.md

# The curated Isaac corpus below is intentionally versioned as a documented
# Qoruyo output and therefore overrides the general generated-output rule.
!syriac-ocr-corpora/
!syriac-ocr-corpora/**/
!syriac-ocr-corpora/**/*.txt
